<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AmongUsCosmeticsManager.ViewModels"
             xmlns:models="using:AmongUsCosmeticsManager.Models"
             xmlns:anim="using:AmongUsCosmeticsManager.Models.Animation"
             xmlns:conv="using:AmongUsCosmeticsManager.Converters"
             xmlns:app="using:AmongUsCosmeticsManager"
             x:Class="AmongUsCosmeticsManager.Views.AnimationTimelinePanel"
             x:DataType="models:FrameListValue">

    <UserControl.Styles>
        <!-- Frame node default -->
        <Style Selector="Border.frame-node">
            <Setter Property="Background" Value="#2d3a5c"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <!-- Frame node active during playback -->
        <Style Selector="Border.frame-node.playhead">
            <Setter Property="BorderBrush" Value="#ee5533"/>
            <Setter Property="Background" Value="#4d5a9c"/>
        </Style>
        <!-- Delay node default -->
        <Style Selector="Border.delay-node">
            <Setter Property="Background" Value="#5c4a2d"/>
            <Setter Property="BorderBrush" Value="#706030"/>
        </Style>
        <!-- Delay node active during playback -->
        <Style Selector="Border.delay-node.playhead">
            <Setter Property="BorderBrush" Value="#ee5533"/>
            <Setter Property="Background" Value="#8c7a4d"/>
        </Style>
        <!-- Custom duration override: bright text -->
        <Style Selector="TextBox">
            <Setter Property="Foreground" Value="#8899bb"/>
        </Style>
        <!-- FPS-calculated default: dimmed text -->
        <Style Selector="TextBox.fpsDefault">
            <Setter Property="Foreground" Value="#556677"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="4">
        <ItemsControl ItemsSource="{Binding Nodes}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.DataTemplates>
                <!-- FrameNode: compact tile with duration -->
                <DataTemplate DataType="anim:FrameNode">
                    <Border Width="104" CornerRadius="4" Margin="2"
                            Classes="frame-node" ClipToBounds="True" Cursor="Hand"
                            BorderThickness="2"
                            DragDrop.AllowDrop="True"
                            PointerPressed="OnNodePointerPressed"
                            PointerMoved="OnNodePointerMoved"
                            Classes.playhead="{Binding IsPlayheadHere}">
                        <StackPanel Spacing="0">
                            <Panel Height="88">
                                <Image Stretch="Uniform" Margin="2">
                                    <Image.Source>
                                        <MultiBinding Converter="{x:Static conv:AdaptiveCosmeticConverter.Instance}">
                                            <Binding Path="Data"/>
                                            <Binding Path="SelectedItem.IsAdaptive" Source="{x:Static app:App.MainVM}"/>
                                            <Binding Path="SelectedPlayerColor" Source="{x:Static app:App.MainVM}"/>
                                        </MultiBinding>
                                    </Image.Source>
                                </Image>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Padding="2" Margin="1"
                                        Background="#80000000" CornerRadius="2"
                                        BorderThickness="0" MinWidth="0" MinHeight="0"
                                        Cursor="Hand" Click="OnRemoveNodeClick">
                                    <PathIcon Data="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                              Width="6" Height="6" Foreground="#cc4444"/>
                                </Button>
                            </Panel>
                            <TextBox Text="{Binding DurationDisplay}" FontSize="9"
                                     Padding="2,1" Background="#1e2844"
                                     BorderThickness="0" HorizontalContentAlignment="Center"
                                     Classes.fpsDefault="{Binding IsUsingFpsDefault}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>

                <!-- DelayNode: full-width block -->
                <DataTemplate DataType="anim:DelayNode">
                    <Border CornerRadius="4" Padding="6,4" Margin="2"
                            Classes="delay-node" BorderThickness="1"
                            Width="{Binding $parent[ItemsControl].Bounds.Width}"
                            DragDrop.AllowDrop="True"
                            PointerPressed="OnNodePointerPressed"
                            PointerMoved="OnNodePointerMoved"
                            Classes.playhead="{Binding IsPlayheadHere}">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*">
                            <PathIcon Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"
                                      Width="12" Height="12" Foreground="#ddaa44"/>
                            <TextBox Grid.Column="1" Text="{Binding DurationMs}" FontSize="11"
                                     Width="50" Padding="3,1" Background="#3a3020"
                                     Foreground="#ddaa44" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="ms" FontSize="10"
                                       Foreground="#aa8833" VerticalAlignment="Center" Margin="4,0"/>
                            <Button Grid.Column="3" Padding="3" Background="Transparent"
                                    BorderThickness="0" MinWidth="0" MinHeight="0"
                                    Cursor="Hand" Click="OnRemoveNodeClick"
                                    HorizontalAlignment="Right">
                                <PathIcon Data="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                          Width="7" Height="7" Foreground="#cc4444"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>

                <!-- LoopNode: full-width container -->
                <DataTemplate DataType="anim:LoopNode">
                    <Border CornerRadius="4" Padding="6,4" Margin="2"
                            Background="#2d5c3a" BorderBrush="#307040" BorderThickness="1"
                            Width="{Binding $parent[ItemsControl].Bounds.Width}"
                            DragDrop.AllowDrop="True"
                            PointerPressed="OnNodePointerPressed"
                            PointerMoved="OnNodePointerMoved">
                        <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="Auto,Auto,Auto,*">
                                <PathIcon Data="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"
                                          Width="12" Height="12" Foreground="#44dd66"/>
                                <TextBlock Grid.Column="1" Text="x" FontSize="11"
                                           Foreground="#44dd66" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <TextBox Grid.Column="2" Text="{Binding Count}" FontSize="11"
                                         Width="32" Padding="3,1" Background="#203a28"
                                         Foreground="#44dd66" VerticalAlignment="Center" Margin="2,0"/>
                                <Button Grid.Column="3" Padding="3" Background="Transparent"
                                        BorderThickness="0" MinWidth="0" MinHeight="0"
                                        Cursor="Hand" Click="OnRemoveNodeClick"
                                        HorizontalAlignment="Right">
                                    <PathIcon Data="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                              Width="7" Height="7" Foreground="#cc4444"/>
                                </Button>
                            </Grid>
                            <!-- Nested children -->
                            <Border Background="#1a3a24" CornerRadius="3" Padding="4"
                                    BorderBrush="#307040" BorderThickness="1,0,0,0" Margin="4,0,0,0">
                                <ItemsControl ItemsSource="{Binding Children}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.DataTemplates>
        </ItemsControl>

        <!-- Add buttons -->
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
            <Button Padding="6,3" FontSize="11" Background="#2d3a5c" Foreground="#aabbdd"
                    BorderThickness="0" CornerRadius="3" Cursor="Hand"
                    Tag="{Binding}" Click="OnAddFrameClick"
                    Content="+ Frame"/>
            <Button Padding="6,3" FontSize="11" Background="#5c4a2d" Foreground="#ddaa44"
                    BorderThickness="0" CornerRadius="3" Cursor="Hand"
                    Tag="{Binding}" Click="OnAddDelayClick"
                    Content="+ Delay"/>
            <Button Padding="6,3" FontSize="11" Background="#2d5c3a" Foreground="#44dd66"
                    BorderThickness="0" CornerRadius="3" Cursor="Hand"
                    Tag="{Binding}" Click="OnAddLoopClick"
                    Content="+ Loop"/>
        </StackPanel>
    </StackPanel>
</UserControl>
