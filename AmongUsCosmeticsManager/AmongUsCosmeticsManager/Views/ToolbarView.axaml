<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AmongUsCosmeticsManager.ViewModels"
             x:Class="AmongUsCosmeticsManager.Views.ToolbarView"
             x:DataType="vm:MainViewModel">
    <Border Classes="toolbar">
        <Grid ColumnDefinitions="Auto,*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                <Button ToolTip.Tip="Ouvrir un projet"
                        Padding="8,4" Background="Transparent" BorderThickness="0"
                        Click="OnOpenProjectClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"
                                  Width="14" Height="14"/>
                        <TextBlock Text="Ouvrir" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button ToolTip.Tip="Enregistrer le projet"
                        Padding="8,4" Background="Transparent" BorderThickness="0"
                        Click="OnSaveProjectClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M17 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"
                                  Width="14" Height="14"/>
                        <TextBlock Text="Enregistrer" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Button>
                <!-- Import menu -->
                <Button Padding="8,4" Background="Transparent" BorderThickness="0">
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                            <MenuItem Header="Bundle Legacy (.bundle)" Click="OnImportLegacyBundleClick"/>
                            <MenuItem Header="Cosmetics Bundle (.bvcb)" Click="OnImportCosmeticsBundleClick"/>
                        </MenuFlyout>
                    </Button.Flyout>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M5 20h14v-2H5v2zm7-18L5.33 9h3.34v4h6.66V9h3.34L12 2z"
                                  Width="14" Height="14"/>
                        <TextBlock Text="Importer" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Rectangle Width="1" Fill="#313145" Margin="4,2"/>
                <Button Command="{Binding ShowAddBundleModalCommand}"
                        ToolTip.Tip="{Binding AppConfig.NewBundleLabel}"
                        Padding="8,4" Background="Transparent" BorderThickness="0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"
                                  Width="14" Height="14"/>
                        <TextBlock Text="{Binding AppConfig.NewBundleLabel}" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding AppConfig.AppName}" FontSize="12" Foreground="#6a6a80"/>
                <TextBlock Text="{Binding AppConfig.Version, StringFormat='v{0}'}" FontSize="10" Foreground="#555570"/>
            </StackPanel>

            <!-- Export menu -->
            <Button Grid.Column="2" Padding="10,4" VerticalAlignment="Center"
                    IsEnabled="{Binding SelectedBundle, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                        <MenuItem Header="Cosmetics Bundle (.bvcb)" Click="OnExportCosmeticsBundleClick"/>
                        <MenuItem Header="Bundle Legacy (.bundle)" Click="OnExportLegacyBundleClick"/>
                    </MenuFlyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                              Width="12" Height="12" Foreground="LimeGreen"/>
                    <TextBlock Text="Exporter" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>
